{
  "name": "varys",
  "version": "0.1.0",
  "description": "Varys — your DS assistant for Jupyter Notebook",
  "keywords": [
    "jupyter",
    "jupyterlab",
    "jupyterlab-extension",
    "ai",
    "data-science"
  ],
  "homepage": "https://github.com/jmlb/varys",
  "bugs": {
    "url": "https://github.com/jmlb/varys/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Jean-Marc Beaujour",
    "email": "jmlbeaujour@gmail.com"
  },
  "files": [
    "lib/**/*.{d.ts,eot,gif,html,jpg,js,js.map,json,png,svg,woff2,ttf}",
    "style/**/*.{css,js,eot,gif,html,jpg,json,png,svg,woff2,ttf}",
    "schema/*.json"
  ],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "style": "style/index.css",
  "repository": {
    "type": "git",
    "url": "https://github.com/jmlb/varys"
  },
  "scripts": {
    "build": "jlpm run build:lib && jlpm run build:labextension:dev",
    "build:prod": "jlpm run clean && jlpm run build:lib:prod && jlpm run build:labextension",
    "build:labextension": "jupyter labextension build .",
    "build:labextension:dev": "jupyter labextension build --development True .",
    "build:lib": "tsc --sourceMap",
    "build:lib:prod": "tsc",
    "clean": "jlpm run clean:lib",
    "clean:lib": "rimraf lib tsconfig.tsbuildinfo",
    "clean:lintcache": "rimraf .eslintcache .stylelintcache",
    "clean:labextension": "rimraf varys/labextension varys/_version.py",
    "clean:all": "jlpm run clean:lib && jlpm run clean:labextension && jlpm run clean:lintcache",
    "install:extension": "jlpm run build",
    "lint": "jlpm eslint . && jlpm stylelint --cache \"style/**/*.css\"",
    "lint:check": "jlpm eslint --cache-strategy content . && jlpm stylelint --cache-strategy content \"style/**/*.css\"",
    "watch": "run-p watch:src watch:labextension",
    "watch:src": "tsc -w --sourceMap",
    "watch:labextension": "jupyter labextension watch ."
  },
  "dependencies": {
    "@jupyterlab/application": "^4.0.0",
    "@jupyterlab/apputils": "^4.0.0",
    "@jupyterlab/cells": "^4.0.0",
    "@jupyterlab/completer": "^4.5.0",
    "@jupyterlab/notebook": "^4.0.0",
    "@jupyterlab/services": "^7.0.0",
    "@jupyterlab/ui-components": "^4.0.0",
    "@lumino/coreutils": "^2.2.2",
    "@lumino/widgets": "^2.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@jupyterlab/builder": "^4.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "rimraf": "^5.0.0",
    "typescript": "~5.1.6"
  },
  "sideEffects": [
    "style/*.css",
    "style/index.js"
  ],
  "styleModule": "style/index.js",
  "publishConfig": {
    "access": "public"
  },
  "jupyterlab": {
    "extension": true,
    "outputDir": "varys/labextension",
    "schemaDir": "schema",
    "_build": {
      "load": "static/remoteEntry.3ba94c411a9400a0cc9a.js",
      "extension": "./extension",
      "style": "./style"
    }
  },
  "jupyter-releaser": {
    "hooks": {
      "before-build-npm": [
        "python -m pip install jupyterlab~=4.0",
        "jlpm"
      ]
    }
  }
}
